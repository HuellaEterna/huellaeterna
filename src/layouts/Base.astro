---
import '@/styles/global.css';
import { SITE } from '@/lib/site';

interface Props {
  title?:       string;
  description?: string;
  image?:       string;
}

const {
  title       = `${SITE.name} | ${SITE.tagline} en ${SITE.city}, ${SITE.country}`,
  description = SITE.description,
  image       = '/og-image.jpg',
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, SITE.url);
const ogImage      = new URL(image, SITE.url);

const jsonLd = {
  '@context':   'https://schema.org',
  '@type':      'LocalBusiness',
  name:         SITE.name,
  description:  SITE.description,
  url:          SITE.url,
  telephone:    SITE.phone,
  priceRange:   '$$',
  image:        ogImage.toString(),
  serviceType:  'Bustos impresos en 3D personalizados de mascotas',
  address: {
    '@type':           'PostalAddress',
    streetAddress:     'Bogotá',
    addressLocality:   SITE.city,
    addressRegion:     'Cundinamarca',
    addressCountry:    'CO',
  },
  geo: {
    '@type':    'GeoCoordinates',
    latitude:   '4.7110',
    longitude:  '-74.0721',
  },
  areaServed: {
    '@type': 'Country',
    name:    'Colombia',
  },
  openingHoursSpecification: {
    '@type':    'OpeningHoursSpecification',
    dayOfWeek:  ['Monday', 'Tuesday', 'Wednesday', 'Thursday', 'Friday', 'Saturday'],
    opens:      '08:00',
    closes:     '20:00',
  },
  hasOfferCatalog: {
    '@type': 'OfferCatalog',
    name:    'Bustos 3D impresos y pintados a mano de mascotas',
    itemListElement: [
      {
        '@type': 'Offer',
        itemOffered: {
          '@type':      'Product',
          name:         'Busto 3D Escultórico — Acabado Mármol',
          description:  'Busto impreso en 3D de mascota con acabado mármol pintado a mano en Bogotá',
        },
        price:          '120000',
        priceCurrency:  'COP',
        availability:   'https://schema.org/InStock',
      },
      {
        '@type': 'Offer',
        itemOffered: {
          '@type':      'Product',
          name:         'Busto 3D Retrato — Acabado Policromado',
          description:  'Busto impreso en 3D de mascota con pintura policromada a mano, acabado premium en Bogotá',
        },
        price:          '280000',
        priceCurrency:  'COP',
        availability:   'https://schema.org/InStock',
      },
    ],
  },
  aggregateRating: {
    '@type':       'AggregateRating',
    ratingValue:   '5',
    reviewCount:   '3',
    bestRating:    '5',
    worstRating:   '1',
  },
  sameAs: [
    `https://wa.me/${SITE.whatsapp}`,
    SITE.instagram,
    SITE.tiktok,
  ],
};
---
<!DOCTYPE html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="theme-color" content="#1A0A2E" />

    <!-- Primary SEO -->
    <title>{title}</title>
    <meta name="description"  content={description} />
    <meta name="keywords"     content={SITE.keywords} />
    <link rel="canonical"     href={canonicalURL} />

    <!-- Geo / Local SEO -->
    <meta name="geo.region"      content="CO-DC" />
    <meta name="geo.placename"   content={SITE.city} />
    <meta name="geo.position"    content="4.7110;-74.0721" />
    <meta name="ICBM"            content="4.7110, -74.0721" />

    <!-- Open Graph -->
    <meta property="og:type"         content="website" />
    <meta property="og:url"          content={canonicalURL} />
    <meta property="og:title"        content={title} />
    <meta property="og:description"  content={description} />
    <meta property="og:image"        content={ogImage} />
    <meta property="og:image:width"  content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt"    content={`${SITE.name} — Bustos impresos en 3D de mascotas en Bogotá, Colombia`} />
    <meta property="og:locale"       content={SITE.locale} />
    <meta property="og:site_name"    content={SITE.name} />

    <!-- Twitter Card -->
    <meta name="twitter:card"        content="summary_large_image" />
    <meta name="twitter:title"       content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image"       content={ogImage} />
    <meta name="twitter:image:alt"   content={`${SITE.name} — Bustos impresos en 3D de mascotas en Bogotá, Colombia`} />

    <!-- Author -->
    <meta name="author" content={SITE.name} />

    <!-- Robots -->
    <meta name="robots" content="index, follow, max-snippet:-1, max-image-preview:large, max-video-preview:-1" />

    <!-- Fonts: preconnect first, then load with display=swap -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="dns-prefetch" href="https://wa.me" />
    <link
      href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,700;0,900;1,400&family=Inter:wght@300;400;500;600;700;800&display=swap"
      rel="stylesheet"
    />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" href="/favicon.svg" />

    <!-- JSON-LD structured data -->
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

    <slot name="head" />
  </head>
  <body>
    <slot />
  </body>
</html>
