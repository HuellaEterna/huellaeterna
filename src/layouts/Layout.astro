---
import { SITE } from '../lib/site.ts';

interface Props {
	title?: string;
	description?: string;
}

const { title = SITE.name, description = SITE.description } = Astro.props;
---

<!doctype html>
<html lang="es" class="scroll-smooth">
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content={description} />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600&family=Playfair+Display:ital,wght@0,700;1,400&display=swap" rel="stylesheet">
		<title>{title}</title>
	</head>
	<body class="bg-[#1A0A2E] text-white overflow-x-hidden" style="font-family: 'Inter', sans-serif;">
		<slot />
	</body>
</html>
