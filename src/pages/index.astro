---
import Base from '../layouts/Base.astro';
import Nav from '../components/Nav.astro';
import Hero from '../components/Hero.astro';
import FinishComparison from '../components/FinishComparison.astro';
import Footer from '../components/Footer.astro';
import WaFloat from '../components/WaFloat.astro';
import ScrollOrbs from '../components/ScrollOrbs.astro';
import Gallery from '../components/Gallery.astro';
import { STEPS, STORY_CARDS, TESTIMONIALS, WA, FUNNEL_CTAS } from '../lib/site';
---

<Base>
	<div class="ambient-bg" aria-hidden="true"></div>
	<ScrollOrbs />
	<Nav />

	<main>
		<Hero />

		<!-- Story Cards -->
		<section class="py-28 px-6 relative z-10">
			<div class="max-w-6xl mx-auto">
				<div class="text-center mb-16">
					<p class="section-tag reveal-up">Nuestra historia</p>
					<h2 class="text-4xl md:text-5xl font-bold mb-4 font-serif reveal-up delay-1">
						Hay amores que no caben<br/>
						<span class="text-gradient">en una sola foto</span>
					</h2>
					<p class="text-white/55 max-w-xl mx-auto leading-relaxed reveal-up delay-2">
						Tu mascota te enseño a amar sin condiciones. Nosotros te ayudamos
						a que ese amor ocupe un lugar de honor en tu hogar.
					</p>
				</div>

				<div class="grid md:grid-cols-3 gap-6" style="perspective: 800px;">
					{STORY_CARDS.map((card, i) => (
						<div class={`glass-card p-8 ${i === 0 ? 'reveal-left' : i === 2 ? 'reveal-right' : 'reveal-up'} delay-${i + 1}`} data-tilt>
							<div class="tilt-shine"></div>
							<span class="text-4xl mb-5 block">{card.emoji}</span>
							<h3 class="text-xl font-bold mb-3 font-serif">{card.title}</h3>
							<p class="text-white/55 text-sm leading-relaxed mb-6">{card.body}</p>
							<a href={WA[card.waKey]} target="_blank" rel="noopener noreferrer" class="text-sm font-semibold text-purple-300 hover:text-pink-400 transition-colors">
								Quiero esto <span aria-hidden="true">&#8594;</span>
							</a>
						</div>
					))}
				</div>
			</div>
		</section>

		<div class="section-divider" aria-hidden="true"></div>

		<!-- Proceso -->
		<section class="py-28 px-6 relative z-10">
			<div class="max-w-4xl mx-auto">
				<div class="text-center mb-20">
					<p class="section-tag reveal-up">Proceso</p>
					<h2 class="text-4xl md:text-5xl font-bold font-serif reveal-up delay-1">El Camino del Artista</h2>
				</div>

				<div class="space-y-14">
					{STEPS.map((step, index) => (
						<div class={`flex gap-8 items-start reveal-left delay-${Math.min(index + 1, 4)}`}>
							<div class="flex flex-col items-center">
								<div class="w-12 h-12 rounded-full border border-purple-500/40 bg-purple-500/10 flex items-center justify-center text-purple-300 font-bold shrink-0 text-sm">
									{index + 1}
								</div>
								{index !== STEPS.length - 1 && <div class="w-px h-20 bg-gradient-to-b from-purple-500/30 to-transparent"></div>}
							</div>
							<div class="pt-2">
								<h3 class="text-xl font-bold mb-2 flex items-center gap-3 font-serif">
									<span class="opacity-70">{step.emoji}</span> {step.title}
								</h3>
								<p class="text-white/50 max-w-xl leading-relaxed text-sm">{step.body}</p>
							</div>
						</div>
					))}
				</div>
			</div>
		</section>

		<div class="section-divider" aria-hidden="true"></div>

		<FinishComparison />

		<div class="section-divider" aria-hidden="true"></div>

		<Gallery />

		<div class="section-divider" aria-hidden="true"></div>

		<!-- Funnel CTAs -->
		<section class="py-28 px-6 relative z-10">
			<div class="max-w-5xl mx-auto">
				<div class="text-center mb-16">
					<p class="section-tag reveal-up">Tu situacion</p>
					<h2 class="text-3xl md:text-4xl font-bold font-serif mb-4 reveal-up delay-1">
						Cual es tu historia?
					</h2>
					<p class="text-white/50 max-w-lg mx-auto reveal-up delay-2">
						Cada persona llega a nosotros por una razon diferente. Encuentra la tuya.
					</p>
				</div>

				<div class="grid md:grid-cols-3 gap-6" style="perspective: 800px;">
					{FUNNEL_CTAS.map((item, i) => (
						<div class={`glass-card p-8 text-center reveal-scale delay-${i + 1}`} data-tilt>
							<div class="tilt-shine"></div>
							<span class="text-4xl mb-4 block">{item.emoji}</span>
							<h3 class="text-lg font-bold mb-2">{item.label}</h3>
							<p class="text-white/50 text-sm leading-relaxed mb-6">{item.desc}</p>
							<a
								href={WA[item.waKey]}
								target="_blank"
								rel="noopener noreferrer"
								class="btn-primary inline-flex text-sm !py-3 !px-6"
							>
								{item.cta}
							</a>
						</div>
					))}
				</div>
			</div>
		</section>

		<div class="section-divider" aria-hidden="true"></div>

		<!-- Testimonios -->
		<section class="py-28 px-6 relative z-10">
			<div class="max-w-6xl mx-auto">
				<div class="text-center mb-16">
					<p class="section-tag reveal-up">Testimonios</p>
					<h2 class="text-4xl font-bold mb-4 font-serif reveal-up delay-1">Historias que perduran</h2>
					<p class="text-purple-300 font-serif italic reveal-up delay-2">El consuelo de un reencuentro a traves del arte</p>
				</div>
				<div class="columns-1 md:columns-2 lg:columns-3 gap-6 space-y-6">
					{TESTIMONIALS.map((t, i) => (
						<div class={`break-inside-avoid glass-card p-8 reveal-scale delay-${Math.min(i + 1, 4)}`}
							itemscope itemtype="https://schema.org/Review">
							<p class="text-white/75 italic mb-6 leading-relaxed font-serif text-sm" itemprop="reviewBody">
								{t.quote}
							</p>
							<div class="flex items-center justify-between border-t border-white/10 pt-5">
								<div itemprop="author" itemscope itemtype="https://schema.org/Person">
									<p class="font-semibold text-sm" itemprop="name">{t.author}</p>
									<p class="text-xs text-white/35">{t.city}</p>
								</div>
								<div class="text-right text-xs">
									<p class="text-purple-300">{t.detail}</p>
									<div class="text-purple-400 mt-1" itemprop="reviewRating" itemscope itemtype="https://schema.org/Rating">
										<meta itemprop="ratingValue" content={t.rating} />
										{"★".repeat(Number(t.rating))}
									</div>
								</div>
							</div>
						</div>
					))}
				</div>
			</div>
		</section>

		<div class="section-divider" aria-hidden="true"></div>

		<!-- CTA Final -->
		<section class="py-28 px-6 text-center relative z-10">
			<div class="max-w-2xl mx-auto reveal-scale">
				<h2 class="text-3xl md:text-5xl font-bold mb-6 leading-tight font-serif">
					Listo para honrar<br/>su huella eterna?
				</h2>
				<p class="text-white/50 mb-10 max-w-md mx-auto">
					Envias las fotos por WhatsApp de forma privada y segura. Nosotros hacemos el resto.
				</p>
				<a
					href={WA.default}
					target="_blank"
					rel="noopener noreferrer"
					class="btn-primary text-lg"
				>
					Hablar con un artista ahora
				</a>
				<p class="mt-8 text-white/25 text-xs">Hecho a mano en Bogota, Colombia para todo el pais.</p>
			</div>
		</section>
	</main>

	<Footer />
	<WaFloat />

	<script>
		// ═══════════════════════════════════════════════════════════════
		// 1. SCROLL REVEAL — IntersectionObserver for all reveal types
		// ═══════════════════════════════════════════════════════════════
		const revealObserver = new IntersectionObserver(
			(entries) => {
				entries.forEach((entry) => {
					if (entry.isIntersecting) {
						entry.target.classList.add('visible');
						revealObserver.unobserve(entry.target);
					}
				});
			},
			{ threshold: 0.12, rootMargin: '0px 0px -60px 0px' }
		);

		document.querySelectorAll('.reveal, .reveal-up, .reveal-left, .reveal-right, .reveal-scale').forEach((el) => {
			revealObserver.observe(el);
		});

		// ═══════════════════════════════════════════════════════════════
		// 2. PARALLAX — Scroll-driven layer movement in hero
		// ═══════════════════════════════════════════════════════════════
		const isMobile = window.matchMedia('(max-width: 768px)').matches;
		const heroSection = document.getElementById('hero');

		if (!isMobile && heroSection) {
			const parallaxLayers = heroSection.querySelectorAll<HTMLElement>('[data-parallax]');
			let ticking = false;

			function updateParallax() {
				const scrollY = window.scrollY;
				const heroH = heroSection!.offsetHeight;

				// Only compute while hero is visible
				if (scrollY > heroH * 1.2) { ticking = false; return; }

				parallaxLayers.forEach((layer) => {
					const speed = parseFloat(layer.dataset.parallax || '0');
					layer.style.transform = `translate3d(0, ${scrollY * speed}px, 0)`;
				});
				ticking = false;
			}

			window.addEventListener('scroll', () => {
				if (!ticking) {
					requestAnimationFrame(updateParallax);
					ticking = true;
				}
			}, { passive: true });
		}

		// ═══════════════════════════════════════════════════════════════
		// 3. CARD TILT — 3D perspective follow on hover
		// ═══════════════════════════════════════════════════════════════
		if (!isMobile) {
			document.querySelectorAll<HTMLElement>('[data-tilt]').forEach((card) => {
				const MAX_ROT = 7; // max degrees

				card.addEventListener('mousemove', (e: MouseEvent) => {
					const rect = card.getBoundingClientRect();
					const x = e.clientX - rect.left;
					const y = e.clientY - rect.top;
					const cx = rect.width / 2;
					const cy = rect.height / 2;

					const rotX = ((y - cy) / cy) * -MAX_ROT;
					const rotY = ((x - cx) / cx) * MAX_ROT;

					card.style.transform = `perspective(800px) rotateX(${rotX.toFixed(2)}deg) rotateY(${rotY.toFixed(2)}deg) scale3d(1.02, 1.02, 1.02)`;
					card.style.transition = 'transform 0.1s ease-out';

					// Update shine position
					const shine = card.querySelector<HTMLElement>('.tilt-shine');
					if (shine) {
						shine.style.setProperty('--shine-x', `${(x / rect.width * 100).toFixed(0)}%`);
						shine.style.setProperty('--shine-y', `${(y / rect.height * 100).toFixed(0)}%`);
					}
				});

				card.addEventListener('mouseleave', () => {
					card.style.transform = 'perspective(800px) rotateX(0) rotateY(0) scale3d(1, 1, 1)';
					card.style.transition = 'transform 0.5s cubic-bezier(0.22, 1, 0.36, 1)';

					const shine = card.querySelector<HTMLElement>('.tilt-shine');
					if (shine) shine.style.opacity = '0';
				});

				card.addEventListener('mouseenter', () => {
					const shine = card.querySelector<HTMLElement>('.tilt-shine');
					if (shine) shine.style.opacity = '1';
				});
			});
		}

		// ═══════════════════════════════════════════════════════════════
		// 4. PRICE COUNTER — Animate from $0 to target on scroll
		// ═══════════════════════════════════════════════════════════════
		const counterObserver = new IntersectionObserver(
			(entries) => {
				entries.forEach((entry) => {
					if (entry.isIntersecting) {
						animateCounter(entry.target as HTMLElement);
						counterObserver.unobserve(entry.target);
					}
				});
			},
			{ threshold: 0.5 }
		);

		document.querySelectorAll<HTMLElement>('[data-count-to]').forEach((el) => {
			counterObserver.observe(el);
		});

		function animateCounter(el: HTMLElement) {
			const target = parseInt(el.dataset.countTo || '0', 10);
			const duration = 2000;
			const start = performance.now();

			function update(now: number) {
				const elapsed = now - start;
				const progress = Math.min(elapsed / duration, 1);
				// Ease-out cubic for natural deceleration
				const eased = 1 - Math.pow(1 - progress, 3);
				const current = Math.round(eased * target);

				// Format as Colombian pesos: $120.000
				el.textContent = '$' + current.toLocaleString('es-CO');

				if (progress < 1) {
					requestAnimationFrame(update);
				}
			}

			requestAnimationFrame(update);
		}
	</script>
</Base>
