---
import { FINISHES, WA } from '../lib/site';
---

<section id="acabados" class="py-28 px-6 relative z-10">
  <div class="max-w-6xl mx-auto text-center mb-16">
    <p class="section-tag">Acabados</p>
    <h2 class="text-4xl md:text-5xl font-bold mb-4 font-serif reveal-up delay-1">Nuestros Acabados</h2>
    <p class="text-white/50 reveal-up delay-2">Dos formas de honrar una vida inolvidable</p>
  </div>

  <div class="grid md:grid-cols-2 gap-8 max-w-5xl mx-auto" style="perspective: 1000px;">
    {FINISHES.map((finish, i) => (
      <div
        class={`tilt-card relative rounded-2xl reveal-scale delay-${i + 1} ${
          finish.highlight
            ? 'p-px bg-gradient-to-b from-purple-500 to-pink-500'
            : 'p-px bg-white/10'
        }`}
        data-tilt
        itemscope
        itemtype="https://schema.org/Product"
      >
        <!-- Shine overlay -->
        <div class="tilt-shine"></div>

        <div class="bg-bg-mid rounded-[calc(1rem-1px)] p-8 h-full flex flex-col relative">
          {finish.highlightLabel && (
            <span class="absolute -top-3.5 left-1/2 -translate-x-1/2 bg-brand text-white px-4 py-1 rounded-full text-[0.6875rem] font-semibold uppercase tracking-wider z-10">
              {finish.highlightLabel}
            </span>
          )}

          <!-- Product photo -->
          <div class="finish-photo-wrap mb-6">
            <img
              src={finish.img}
              alt={finish.imgAlt}
              width="360"
              height="280"
              loading="lazy"
              decoding="async"
              class="finish-photo"
            />
          </div>

          <h3 class="text-2xl font-bold mb-1 font-serif" itemprop="name">{finish.name}</h3>
          <p class="text-purple-300 font-serif italic mb-6 text-sm">{finish.subtitle}</p>

          <div class="text-4xl font-bold mb-6" itemprop="offers" itemscope itemtype="https://schema.org/Offer">
            <span
              class="price-counter"
              data-count-to={finish.priceNum}
              itemprop="price"
              content={finish.priceNum}
            >{finish.price}</span>
            <span class="text-sm font-normal text-white/35" itemprop="priceCurrency" content="COP"> {finish.currency}</span>
            <meta itemprop="availability" content="https://schema.org/InStock" />
          </div>

          <p class="text-white/55 mb-8 leading-relaxed text-sm">{finish.description}</p>

          <ul class="space-y-3.5 mb-10 flex-grow text-left">
            {finish.features.map(feature => (
              <li class="flex items-center gap-3 text-sm text-white/70">
                <span class="text-purple-400 text-xs">&#10003;</span> {feature}
              </li>
            ))}
          </ul>

          <a
            href={WA[finish.waKey]}
            target="_blank"
            rel="noopener noreferrer"
            class={`w-full py-3.5 rounded-xl font-semibold transition-all text-center text-sm ${
              finish.highlight
                ? 'btn-primary justify-center !rounded-xl'
                : 'border border-white/15 text-white hover:bg-white/5 hover:border-purple-500/40'
            }`}
          >
            Cotizar este acabado
          </a>
        </div>
      </div>
    ))}
  </div>
</section>

<style>
  .finish-photo-wrap {
    border-radius: 0.875rem;
    overflow: hidden;
    margin: -2rem -2rem 1.5rem -2rem;
    /* altura = aspect-ratio natural de las fotos (portrait ~4:5) */
    aspect-ratio: 4 / 3.5;
    background: rgba(45, 16, 87, .6);
  }

  .finish-photo {
    width: 100%;
    height: 100%;
    object-fit: contain;
    object-position: center center;
    display: block;
    padding: 0.5rem;
    transition: transform 0.6s cubic-bezier(0.22, 1, 0.36, 1);
  }

  [data-tilt]:hover .finish-photo {
    transform: scale(1.03);
  }
</style>
