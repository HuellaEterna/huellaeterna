---
import { SITE, WA } from '@/lib/site';
---
<header>
  <nav id="site-nav" aria-label="Navegación principal">
    <a href="/" class="nav-logo" aria-label={SITE.name}>
      <img
        src="/images/busto-3d-mascota-huella-eterna-logo-bogota.jpeg"
        alt="Huella Eterna — Bustos 3D Colombia"
        width="38"
        height="38"
        class="nav-logo-img"
      />
      <span class="nav-brand">{SITE.name}</span>
    </a>

    <a href={WA.default} target="_blank" rel="noopener noreferrer" class="nav-cta">
      Cotizar ahora
    </a>
  </nav>
</header>

<style>
  header {
    position: fixed;
    top: 0; left: 0; right: 0;
    z-index: 100;
  }

  nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 1rem 2rem;
    background: rgba(28, 16, 48, .75);
    backdrop-filter: blur(24px) saturate(160%);
    -webkit-backdrop-filter: blur(24px) saturate(160%);
    border-bottom: 1px solid rgba(255, 255, 255, .07);
    transition: transform .3s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .nav-logo {
    display: flex;
    align-items: center;
    gap: 12px;
    text-decoration: none;
  }

  .nav-logo-img {
    width: 38px;
    height: 38px;
    border-radius: 50%;
    object-fit: cover;
    flex-shrink: 0;
  }

  .nav-brand {
    font-family: 'Playfair Display', Georgia, serif;
    font-size: 1.1875rem;
    font-weight: 700;
    letter-spacing: -0.01em;
    color: #fff;
  }

  .nav-cta {
    background: linear-gradient(135deg, #9B7FD4, #C084FC);
    color: #fff;
    border: none;
    border-radius: 50px;
    padding: 9px 22px;
    font-family: -apple-system, BlinkMacSystemFont, 'Inter', system-ui, sans-serif;
    font-size: .875rem;
    font-weight: 600;
    letter-spacing: -0.01em;
    text-decoration: none;
    box-shadow: 0 3px 14px rgba(155, 127, 212, .35);
    transition: transform .2s cubic-bezier(0.4, 0, 0.2, 1), box-shadow .2s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .nav-cta:hover {
    transform: translateY(-1px) scale(1.02);
    box-shadow: 0 6px 22px rgba(155, 127, 212, .55);
  }

  @media (max-width: 480px) {
    nav { padding: 1rem 1.25rem; }
    .nav-brand { font-size: 1.0625rem; }
  }
</style>
