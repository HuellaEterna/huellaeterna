---
import { WA, FUNNEL_CTAS, PRICE_FEATURES } from '@/lib/site';
---
<section id="prices" aria-labelledby="prices-heading">
  <div class="section-inner">
    <h2 id="prices-heading" class="section-title reveal">
      Porque su amor <span class="text-gradient">no tenía precio</span>,<br>
      pero sí su busto
    </h2>

    <div class="price-card reveal reveal-delay-1" aria-label="Información de precios">
      <p class="price-from">Bustos 3D pintados a mano desde</p>
      <p class="price-main" aria-label="Desde $120.000 pesos colombianos">$120.000 <span>COP</span></p>
      <p class="price-desc">
        Cada pieza es única, impresa en 3D desde tus fotos y pintada a mano.<br>
        El precio más pequeño al lado de lo que tu mascota significa.
      </p>

      <ul class="price-features" aria-label="Características del servicio">
        {PRICE_FEATURES.map(feat => (
          <li>{feat}</li>
        ))}
      </ul>
    </div>

    <!-- Funnel redesigned as visual cards -->
    <div class="funnel" aria-labelledby="funnel-heading">
      <p id="funnel-heading" class="funnel-title reveal reveal-delay-1">
        ¿Cuál es tu situación?
      </p>
      <p class="funnel-sub reveal reveal-delay-2">
        Cuéntanos y te guiamos por WhatsApp en minutos.
      </p>

      <div class="funnel-grid">
        {FUNNEL_CTAS.map((item, i) => (
          <a
            href={WA[item.waKey]}
            target="_blank"
            rel="noopener noreferrer"
            class={`funnel-card reveal reveal-delay-${i + 2}`}
            aria-label={`${item.label} — Cotizar por WhatsApp`}
          >
            <div class="funnel-card-top">
              <span class="funnel-icon" aria-hidden="true">{item.emoji}</span>
            </div>
            <div class="funnel-card-body">
              <h3 class="funnel-label">{item.label}</h3>
              <p class="funnel-desc">{item.desc}</p>
            </div>
            <div class="funnel-card-footer">
              <span class="funnel-cta-text">{item.cta}</span>
              <span class="funnel-arrow" aria-hidden="true">→</span>
            </div>
          </a>
        ))}
      </div>

      <p class="funnel-note reveal reveal-delay-4">
        <span aria-hidden="true">🔒</span>
        Cada mensaje llega directo a nuestro WhatsApp. Te respondemos en minutos.
      </p>
    </div>
  </div>
</section>

<style>
  #prices { padding: 6.25rem 0; }

  #prices .section-title { margin-bottom: 3rem; text-align: center; }

  .price-card {
    background: rgba(45, 16, 87, .38);
    backdrop-filter: blur(24px) saturate(160%);
    -webkit-backdrop-filter: blur(24px) saturate(160%);
    border: 1px solid rgba(255, 255, 255, .08);
    border-radius: 1.25rem;
    padding: 2.5rem;
    text-align: center;
    max-width: 560px;
    margin: 0 auto 4.5rem;
  }

  .price-from {
    font-size: .75rem;
    font-weight: 600;
    letter-spacing: .08em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, .45);
    margin-bottom: .5rem;
  }

  .price-main {
    font-family: 'Playfair Display', Georgia, serif;
    font-size: 3.5rem;
    font-weight: 900;
    letter-spacing: -0.03em;
    background: linear-gradient(135deg, #A855F7, #EC4899);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    line-height: 1;
    margin-bottom: .5rem;
  }

  .price-main span {
    font-size: 1rem;
    font-weight: 400;
    color: rgba(255, 255, 255, .4);
    -webkit-text-fill-color: rgba(255, 255, 255, .4);
  }

  .price-desc {
    font-size: .9375rem;
    color: rgba(255, 255, 255, .6);
    line-height: 1.75;
    margin-bottom: 1.5rem;
  }

  .price-features {
    list-style: none;
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: .625rem;
  }

  .price-features li {
    background: rgba(168, 85, 247, .12);
    border: 1px solid rgba(168, 85, 247, .22);
    border-radius: 50px;
    padding: 6px 16px;
    font-size: .8125rem;
    font-weight: 500;
    color: rgba(255, 255, 255, .72);
  }

  /* ── Funnel ────────────────────────────────────────────────────────────── */
  .funnel { text-align: center; }

  .funnel-title {
    font-family: 'Playfair Display', Georgia, serif;
    font-size: clamp(1.375rem, 3vw, 2rem);
    font-weight: 700;
    letter-spacing: -0.02em;
    color: #fff;
    margin-bottom: .625rem;
  }

  .funnel-sub {
    font-size: .9375rem;
    color: rgba(255, 255, 255, .45);
    margin-bottom: 2.5rem;
  }

  .funnel-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.25rem;
    max-width: 860px;
    margin: 0 auto 2rem;
  }

  .funnel-card {
    display: flex;
    flex-direction: column;
    background: rgba(255, 255, 255, .04);
    border: 1px solid rgba(255, 255, 255, .09);
    border-radius: 1.25rem;
    overflow: hidden;
    text-decoration: none;
    color: #fff;
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    transition: transform .25s cubic-bezier(0.4, 0, 0.2, 1),
                border-color .25s cubic-bezier(0.4, 0, 0.2, 1),
                box-shadow .25s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .funnel-card:hover {
    transform: translateY(-5px);
    border-color: rgba(168, 85, 247, .4);
    box-shadow: 0 16px 40px rgba(168, 85, 247, .15);
  }

  .funnel-card-top {
    background: linear-gradient(135deg, rgba(91, 33, 182, .5), rgba(236, 72, 153, .3));
    padding: 2rem 1.5rem 1.5rem;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .funnel-icon {
    font-size: 2.75rem;
    line-height: 1;
    filter: drop-shadow(0 4px 12px rgba(168, 85, 247, .4));
  }

  .funnel-card-body {
    padding: 1.25rem 1.5rem;
    flex: 1;
    text-align: left;
  }

  .funnel-label {
    font-family: -apple-system, BlinkMacSystemFont, 'Inter', system-ui, sans-serif;
    font-size: 1rem;
    font-weight: 700;
    letter-spacing: -0.01em;
    color: #fff;
    margin-bottom: .625rem;
  }

  .funnel-desc {
    font-size: .875rem;
    font-weight: 400;
    color: rgba(255, 255, 255, .55);
    line-height: 1.75;
  }

  .funnel-card-footer {
    padding: 1rem 1.5rem 1.25rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    border-top: 1px solid rgba(255, 255, 255, .07);
  }

  .funnel-cta-text {
    font-size: .875rem;
    font-weight: 600;
    color: #C084FC;
    letter-spacing: -0.005em;
  }

  .funnel-arrow {
    font-size: 1rem;
    color: #C084FC;
    transition: transform .2s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .funnel-card:hover .funnel-arrow {
    transform: translateX(4px);
  }

  .funnel-note {
    font-size: .8125rem;
    color: rgba(255, 255, 255, .35);
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 6px;
    margin-top: .5rem;
  }

  @media (max-width: 768px) {
    .funnel-grid { grid-template-columns: 1fr; max-width: 420px; }
  }

  @media (min-width: 769px) and (max-width: 1024px) {
    .funnel-grid { grid-template-columns: 1fr 1fr 1fr; gap: 1rem; }
    .funnel-card-body { padding: 1rem 1.25rem; }
  }
</style>
